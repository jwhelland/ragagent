# Application
APP_ENV=development
LOG_LEVEL=INFO

# OpenAI (used for chat; embeddings served locally)
OPENAI_API_KEY=sk-your-key

# Vector DB (Qdrant)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=cosine

# Graph DB (Neo4j)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# Local Embeddings Service
EMBEDDINGS_ENDPOINT=http://embeddings:8080/embed

# OCR / Parsing
OCR_ENGINE=easyocr
OCR_LANGUAGES=en

# spaCy
SPACY_MODEL=en_core_web_sm
